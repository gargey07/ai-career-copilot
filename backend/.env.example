# ═══════════════════════════════════════════════════════
# AI Career Copilot — Environment Variables
# Copy this to .env and fill in your actual values
# NEVER commit .env to git
# ═══════════════════════════════════════════════════════

# ── Supabase (Database) ─────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key
SUPABASE_SERVICE_KEY=your_service_role_key        # backend only, never expose to frontend

# ── Local Dev Database (Docker) ─────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_career_copilot

# ── Redis (Task Queue & Cache) ──────────────────────────
REDIS_URL=redis://localhost:6379

# ── Job Source APIs ─────────────────────────────────────
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
JSEARCH_API_KEY=your_rapidapi_key                 # from rapidapi.com → JSearch

# ── Email Finding ───────────────────────────────────────
HUNTER_API_KEY=your_hunter_io_api_key

# ── AI Providers ────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key                # from aistudio.google.com
OPENAI_API_KEY=your_openai_api_key                # optional fallback
AI_PROVIDER=gemini                                 # 'gemini' | 'openai'

# Optional generate_text-only fallback waterfall (AI_PROVIDER=gemini only):
# if Gemini errors or hits its rate limit mid-pipeline, the next one of
# these with a key set is tried automatically, in this order. Leave any/all
# blank to skip them — nothing here is required. Embeddings always stay on
# Gemini regardless of these.
GROQ_API_KEY=                                      # console.groq.com
OPENROUTER_API_KEY=                                # openrouter.ai/keys
GITHUB_MODELS_TOKEN=                               # GitHub PAT with 'models:read' scope
MISTRAL_API_KEY=                                   # console.mistral.ai
COHERE_API_KEY=                                    # dashboard.cohere.com

# ── File Storage (Cloudflare R2) ────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=ai-copilot-resumes
R2_PUBLIC_URL=https://pub-xxxx.r2.dev            # your public bucket URL

# ── Email Sending ───────────────────────────────────────
RESEND_API_KEY=your_resend_api_key                # from resend.com
EMAIL_FROM=hello@yourdomain.com
EMAIL_FROM_NAME=AI Career Copilot

# Gmail SMTP fallback (if not using Resend)
GMAIL_USER=your@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# ── App Config ──────────────────────────────────────────
APP_ENV=development                                # 'development' | 'production'
APP_SECRET_KEY=your_super_secret_key_here         # for JWT signing
FOUNDER_EMAIL=gargeypatel123@gmail.com
DIGEST_TIME=07:00                                  # time to send morning digest (24h)
MAX_JOBS_PER_USER=10                               # how many jobs to match
AI_JOBS_PER_USER=3                                 # how many to generate AI content for

# ── Daily API Budget Caps (0 = unlimited) ───────────────
# Prevents the pipeline from burning through free-tier quotas or racking
# up spend. Defaults are conservative — check your actual plan limits
# (Adzuna/RapidAPI/Google AI Studio/Resend dashboards) and adjust here.
ADZUNA_DAILY_LIMIT=200
JSEARCH_DAILY_LIMIT=5
GEMINI_GENERATE_DAILY_LIMIT=20     # free-tier gemini-2.5-flash is really ~20/day per Google's own 429s
GEMINI_EMBED_DAILY_LIMIT=500
OPENAI_DAILY_LIMIT=50
RESEND_DAILY_LIMIT=100
JOB_ANALYSES_PER_USER_DAILY=10     # add-a-job intake + per-match "Analyze" clicks, per user
